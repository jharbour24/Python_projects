 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Build Movement Density and Sales Velocity Scores\n",
    "\n",
    "This notebook processes raw data into weekly features and computes:\n",
    "- **Movement Density Score (MDS)**: Weighted combination of social engagement metrics\n",
    "- **Sales Velocity Score (SV)**: Weighted combination of sales proxy metrics\n",
    "\n",
    "**Input:** Processed data from `data/processed/`\n",
    "\n",
    "**Output:** Weekly MDS and SV scores by show"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.append('..')\n",
    "\n",
    "import yaml\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Import processing modules\n",
    "from src.processing.features import build_features_for_show\n",
    "from src.processing.scores import build_mds, build_sv, build_scores_for_show\n",
    "from src.processing.align import align_relative_timeline, create_aligned_timeline_all_shows"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load configuration\n",
    "with open('../config/shows.yaml', 'r') as f:\n",
    "    config = yaml.safe_load(f)\n",
    "\n",
    "shows = config['shows']\n",
    "print(f\"Loaded configuration for {len(shows)} shows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Processed Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "processed_dir = Path('../data/processed')\n",
    "\n",
    "def load_show_data(show_name):\n",
    "    \"\"\"Load all processed data files for a show.\"\"\"\n",
    "    show_slug = show_name.replace(' ', '_')\n",
    "    \n",
    "    data = {\n",
    "        'instagram': pd.DataFrame(),\n",
    "        'tiktok': pd.DataFrame(),\n",
    "        'reddit_posts': pd.DataFrame(),\n",
    "        'reddit_comments': pd.DataFrame(),\n",
    "        'trends': pd.DataFrame(),\n",
    "        'grosses': pd.DataFrame(),\n",
    "        'prices': pd.DataFrame(),\n",
    "        'discounts': pd.DataFrame(),\n",
    "    }\n",
    "    \n",
    "    # Try to load each file\n",
    "    for key in data.keys():\n",
    "        file_path = processed_dir / f'{show_slug}_{key}.csv'\n",
    "        if file_path.exists():\n",
    "            try:\n",
    "                data[key] = pd.read_csv(file_path)\n",
    "            except Exception as e:\n",
    "                print(f\"Warning: Could not load {file_path}: {e}\")\n",
    "    \n",
    "    return data\n",
    "\n",
    "# Load data for all shows\n",
    "all_show_data = {}\n",
    "\n",
    "for show_id, show_info in shows.items():\n",
    "    show_name = show_info['name']\n",
    "    print(f\"Loading data for {show_name}...\")\n",
    "    all_show_data[show_name] = load_show_data(show_name)\n",
    "\n",
    "print(f\"\\nLoaded data for {len(all_show_data)} shows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Build Features and Scores"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build features and scores for each show\n",
    "all_features = {}\n",
    "all_scores = {}\n",
    "\n",
    "for show_name, data in tqdm(all_show_data.items(), desc=\"Building scores\"):\n",
    "    print(f\"\\nProcessing {show_name}...\")\n",
    "    \n",
    "    # Build features\n",
    "    features_df = build_features_for_show(\n",
    "        show_name=show_name,\n",
    "        instagram_df=data['instagram'],\n",
    "        tiktok_df=data['tiktok'],\n",
    "        reddit_posts_df=data['reddit_posts'],\n",
    "        reddit_comments_df=data['reddit_comments'],\n",
    "        trends_df=data['trends'],\n",
    "    )\n",
    "    \n",
    "    all_features[show_name] = features_df\n",
    "    \n",
    "    # Build scores\n",
    "    if not features_df.empty:\n",
    "        scores_df = build_scores_for_show(\n",
    "            features_df=features_df,\n",
    "            grosses_df=data['grosses'],\n",
    "            prices_df=data['prices'],\n",
    "            discounts_df=data['discounts'],\n",
    "        )\n",
    "        \n",
    "        all_scores[show_name] = scores_df\n",
    "        \n",
    "        print(f\"  Generated {len(scores_df)} weeks of scores\")\n",
    "        print(f\"  MDS range: [{scores_df['mds'].min():.2f}, {scores_df['mds'].max():.2f}]\")\n",
    "        print(f\"  SV range: [{scores_df['sv'].min():.2f}, {scores_df['sv'].max():.2f}]\")\n",
    "    else:\n",
    "        print(f\"  Warning: No features generated for {show_name}\")\n",
    "        all_scores[show_name] = pd.DataFrame()\n",
    "\n",
    "print(f\"\\nScore calculation complete for {len(all_scores)} shows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Align to Relative Timeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create aligned timeline for all shows\n",
    "aligned_df = create_aligned_timeline_all_shows(\n",
    "    shows_config=shows,\n",
    "    scores_by_show=all_scores,\n",
    "    weeks_before=4,\n",
    "    weeks_after=12,\n",
    ")\n",
    "\n",
    "print(f\"\\nAligned timeline created with {len(aligned_df)} observations\")\n",
    "print(f\"Shows included: {aligned_df['show_name'].nunique()}\")\n",
    "print(f\"Week range: {aligned_df['week_relative'].min()} to {aligned_df['week_relative'].max()}\")\n",
    "\n",
    "# Display summary\n",
    "print(\"\\nData availability by show:\")\n",
    "summary = aligned_df.groupby('show_name').agg({\n",
    "    'mds': lambda x: (~x.isna()).sum(),\n",
    "    'sv': lambda x: (~x.isna()).sum(),\n",
    "})\n",
    "summary.columns = ['MDS weeks', 'SV weeks']\n",
    "print(summary)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Save Scores and Aligned Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save individual show scores\n",
    "scores_dir = Path('../data/processed/scores')\n",
    "scores_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "for show_name, scores_df in all_scores.items():\n",
    "    if not scores_df.empty:\n",
    "        filename = show_name.replace(' ', '_') + '_scores.csv'\n",
    "        scores_df.to_csv(scores_dir / filename, index=False)\n",
    "\n",
    "print(f\"Individual scores saved to {scores_dir}/\")\n",
    "\n",
    "# Save aligned timeline\n",
    "aligned_path = Path('../data/processed/aligned_mds_sv.csv')\n",
    "aligned_df.to_csv(aligned_path, index=False)\n",
    "print(f\"\\nAligned timeline saved to {aligned_path}\")\n",
    "\n",
    "# Save features\n",
    "features_dir = Path('../data/processed/features')\n",
    "features_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "for show_name, features_df in all_features.items():\n",
    "    if not features_df.empty:\n",
    "        filename = show_name.replace(' ', '_') + '_features.csv'\n",
    "        features_df.to_csv(features_dir / filename, index=False)\n",
    "\n",
    "print(f\"Features saved to {features_dir}/\")\n",
    "\n",
    "print(\"\\nScore building complete!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary\n",
    "\n",
    "This notebook:\n",
    "1. Extracted weekly features from raw social and web data\n",
    "2. Computed Movement Density Score (MDS) from engagement features\n",
    "3. Computed Sales Velocity (SV) from sales proxy features\n",
    "4. Aligned all shows to relative timeline (weeks from opening)\n",
    "\n",
    "Next: Run `03_analysis.ipynb` to test the MDS-SV relationship"
   ]
  }
 ],
